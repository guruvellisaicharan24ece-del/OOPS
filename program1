class student:

    def __init__(self, name, age, marks1, marks2, marks3, feebal):
        self.name = name
        self.age = age
        self.marks1 = marks1
        self.marks2 = marks2
        self.marks3 = marks3
        self.feebal = feebal

    def calculate_average(self):
        return (self.marks1 + self.marks2 + self.marks3) / 3

    def calculate_CGPA(self):
        avg = self.calculate_average()
        return avg / 10

    def display(self):
        print("Student name:", self.name)
        print("Age:", self.age)
        print("Average:", self.calculate_average())
        print("CGPA:", self.calculate_CGPA())
        print("Fee balance:", self.feebal)
